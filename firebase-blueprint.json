{
  "entities": {
    "Place": {
      "title": "Place",
      "description": "A travel destination or memory",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the place" },
        "address": { "type": "string", "description": "Address for navigation" },
        "visited": { "type": "boolean", "description": "Whether the place has been visited" },
        "rating": { "type": "number", "description": "Rating out of 5" },
        "note": { "type": "string", "description": "Personal note or memory about the visit" },
        "photos": { "type": "array", "description": "List of photo URLs stored in cloud" },
        "visitedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "category": { "type": "string", "description": "Category like Yemek, Alkol, etc" },
        "isFavorite": { "type": "boolean", "description": "Whether the place is a favorite" },
        "muratRating": { "type": "number", "description": "Rating given by Murat" },
        "cansuRating": { "type": "number", "description": "Rating given by Cansu" },
        "ownerId": { "type": "string", "description": "ID of the user who added it" }
      },
      "required": ["name", "address", "visited", "category", "isFavorite", "muratRating", "cansuRating"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Activity stream for Cansu & Murat",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "sender": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      },
      "required": ["text", "sender", "type", "createdAt", "isRead"]
    }
  },
  "firestore": {
    "/places/{placeId}": {
      "schema": "Place",
      "description": "Collection of places to visit and memories"
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "Live activity feed"
    }
  }
}
