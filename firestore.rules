rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validation ---
    function isValidPlace(data) {
      return data.keys().hasAll(['name', 'address', 'visited', 'rating', 'photos', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.address is string && data.address.size() <= 500 &&
             data.visited is bool &&
             data.rating is number && data.rating >= 0 && data.rating <= 5 &&
             data.photos is list && data.photos.size() <= 6 &&
             (data.visited == false || (data.visited == true && data.keys().hasAll(['visitedAt', 'note'])));
    }

    // --- Handshake ---
    match /test/connection {
      allow read: if true;
    }

    match /places/{placeId} {
      // TEST: Okuma iznini geçici olarak herkese açarak sorunu daraltıyoruz
      allow read: if true;
      
      allow create: if request.auth != null && 
                      isValidId(placeId) && 
                      isValidPlace(incoming()) &&
                      incoming().createdAt == request.time &&
                      incoming().visited == false;

      allow update: if request.auth != null &&
                      isValidPlace(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      (
                        // Action: Mark as Visited
                        (existing().visited == false && incoming().visited == true && 
                         incoming().visitedAt == request.time &&
                         incoming().diff(existing()).affectedKeys().hasAll(['visited', 'visitedAt', 'rating', 'note', 'photos'])) ||
                        // Action: Casual update (name/address)
                        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'address', 'photos', 'rating', 'note']))
                      );

      allow delete: if request.auth != null;
    }
  }
}
