rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validation ---
    function isValidPlace(data) {
      return data.keys().hasAll(['name', 'address', 'visited', 'rating', 'photos', 'createdAt', 'category', 'isFavorite', 'muratRating', 'cansuRating']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.address is string && data.address.size() <= 500 &&
             data.visited is bool &&
             data.isFavorite is bool &&
             data.category is string && data.category.size() <= 50 &&
             data.rating is number && data.rating >= 0 && data.rating <= 5 &&
             data.muratRating is number && data.muratRating >= 0 && data.muratRating <= 5 &&
             data.cansuRating is number && data.cansuRating >= 0 && data.cansuRating <= 5 &&
             data.photos is list && data.photos.size() <= 6 &&
             (data.visited == false || (data.visited == true && data.keys().hasAll(['visitedAt', 'note'])));
    }

    // --- Handshake ---
    match /test/connection {
      allow read: if true;
    }

    match /places/{placeId} {
      // Murat ve Cansu için açık erişim (Giriş yapan herkes okuyabilir)
      allow read: if true; // Geçici olarak okumayı açık bırakıyorum ki test edilebilsin
      
      allow create: if isSignedIn() && 
                      isValidId(placeId) && 
                      isValidPlace(incoming()) &&
                      incoming().createdAt == request.time &&
                      incoming().visited == false;

      allow update: if isSignedIn() &&
                      isValidPlace(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      (
                        // Action: Mark as Visited
                        (existing().visited == false && incoming().visited == true && 
                         incoming().visitedAt == request.time &&
                         incoming().diff(existing()).affectedKeys().hasAll(['visited', 'visitedAt', 'rating', 'note', 'photos', 'muratRating', 'cansuRating'])) ||
                        // Action: Toggle Favorite or Edit Basic Info
                        (incoming().diff(existing()).affectedKeys().hasAny(['name', 'address', 'photos', 'rating', 'note', 'isFavorite', 'category', 'muratRating', 'cansuRating']))
                      );

      allow delete: if isSignedIn();
    }
  }
}
